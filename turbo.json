{
  "$schema": "https://v2-8-13.turborepo.dev/schema.json",
  "globalEnv": ["CI", "AGENTX_DISABLE_SHARE"],
  "globalPassThroughEnv": ["CI", "AGENTX_DISABLE_SHARE"],
  "tasks": {
    "typecheck": {},
    "build": {
      "dependsOn": [],
      "outputs": ["dist/**"]
    },
    "agentx#test": {
      "dependsOn": ["^build"],
      "outputs": [],
      "passThroughEnv": ["*"]
    },
    "@agentx-cli/app#test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@agentx-cli/ui#test": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
